{
  "name": "ryskbot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Telegram bot that tracks Rysk Finance positions and notifies on expiry.",
  "scripts": {
    "dev": "vercel dev",
    "deploy": "vercel --prod",
    "typecheck": "tsc --noEmit",
    "set-webhook": "tsx scripts/set-webhook.ts",
    "check-redis": "tsx scripts/check-redis.ts",
    "smoke": "tsx scripts/smoke.ts",
    "set-commands": "tsx scripts/set-commands.ts"
  },
  "dependencies": {
    "@upstash/redis": "^1.34.3",
    "grammy": "^1.30.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vercel": "^37.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
